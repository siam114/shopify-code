{%- style -%}
  .video-slider-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mb }}px;
    padding-bottom: {{ section.settings.padding_bottom_mb }}px;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }


  @media screen and (min-width: 750px) {
    .video-slider-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }


  .video-slider-wrapper {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 15px;
    position: relative;
  }


  .section-header {
    margin-bottom: 30px;
    text-align: center;
    padding: 0 10px;
  }


  .section-header h2 {
    margin: 0 0 10px 0;
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.text_color }};
    font-weight: bold;
    text-transform: uppercase;
    line-height: 1.2;
  }


  .section-header .description {
    margin: 0 auto;
    font-size: {{ section.settings.desc_size }}px;
    color: {{ section.settings.text_color }};
    opacity: 0.8;
    max-width: 700px;
    line-height: 1.5;
  }


  /* Slider Main Styles */
  .video-carousel {
    width: 100%;
    margin: 0 auto;
  }


  .video-slide {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }


  .video-slide video {
    width: 100%;
    max-width: {{ section.settings.video_width }}px;
    height: auto;
    max-height: 80vh;
    border-radius: 12px;
    display: block;
    background: #000;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    object-fit: contain;
  }


  /* Custom Arrow Buttons */
  .flickity-prev-next-button {
    width: 40px;
    height: 40px;
    background: #fff !important;
    border: 1px solid #ddd !important;
    border-radius: 4px !important;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    z-index: 10;
    transition: opacity 0.3s ease;
  }


  .flickity-prev-next-button.previous { left: 5px; }
  .flickity-prev-next-button.next { right: 5px; }


  @media screen and (min-width: 1200px) {
    .flickity-prev-next-button.previous { left: -50px; }
    .flickity-prev-next-button.next { right: -50px; }
  }


  .flickity-prev-next-button svg {
    fill: #000;
    width: 35%;
    height: 35%;
  }


  /* Full Responsive adjustments */
  @media screen and (max-width: 749px) {
    .section-header h2 {
      font-size: calc({{ section.settings.heading_size }}px * 0.8);
    }
    .section-header .description {
      font-size: calc({{ section.settings.desc_size }}px * 0.9);
    }
    .video-slide video {
      max-height: 65vh;
    }
    .flickity-prev-next-button {
      width: 35px;
      height: 35px;
      top: 40%; /* Video-r center e rakhar jonno */
    }
  }


  .flickity-page-dots {
    bottom: -35px;
  }
 
  .flickity-page-dots .dot {
    background: {{ section.settings.text_color }};
  }
{%- endstyle -%}


<link rel="stylesheet" href="https://unpkg.com/flickity@2/dist/flickity.min.css">
<script src="https://unpkg.com/flickity@2/dist/flickity.pkgd.min.js"></script>


<section class="video-slider-{{ section.id }}">
  <div class="video-slider-wrapper">
   
    <div class="section-header">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <div class="description">{{ section.settings.description }}</div>
      {% endif %}
    </div>


    <div class="video-carousel"
         data-flickity='{
           "cellAlign": "center",
           "contain": true,
           "wrapAround": true,
           "adaptiveHeight": true,
           "prevNextButtons": {{ section.settings.show_arrows }},
           "pageDots": {{ section.settings.show_dots }},
           "watchCSS": false
         }'>
     
      {% for block in section.blocks %}
        <div class="video-slide" {{ block.shopify_attributes }}>
          {% if block.settings.video_url_mp4 != blank %}
            <video
              controls
              playsinline
              preload="metadata"
              poster="{{ block.settings.video_poster | image_url: width: 1200 }}"
            >
              <source src="{{ block.settings.video_url_mp4 }}" type="video/mp4">
            </video>
          {% else %}
             <div style="background: #111; width: 100%; max-width: {{ section.settings.video_width }}px; height: 350px; color: #fff; display: flex; align-items: center; justify-content: center; border-radius: 12px;">
               Upload Video in Blocks
             </div>
          {% endif %}
        </div>
      {% endfor %}


    </div>
  </div>
</section>


{% schema %}
{
  "name": "Custom Video Slider",
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "WATCH BREEZE MAN IN ACTION"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section Description",
      "default": "STORY READINGS FROM THE SERIES"
    },
    {
      "type": "header",
      "content": "Typography & Colors"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Heading Font Size",
      "default": 32
    },
    {
      "type": "range",
      "id": "desc_size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Description Font Size",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & Icons Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "number",
      "id": "container_width",
      "label": "Max Container Width (px)",
      "default": 1200
    },
    {
      "type": "number",
      "id": "video_width",
      "label": "Video Width (px)",
      "default": 1000
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show Dots",
      "default": true
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mb",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mb",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "video_slide",
      "name": "Video Slide",
      "settings": [
        {
          "type": "url",
          "id": "video_url_mp4",
          "label": "MP4 Video URL"
        },
        {
          "type": "image_picker",
          "id": "video_poster",
          "label": "Video Thumbnail"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Video Slider"
    }
  ]
}
{% endschema %}
