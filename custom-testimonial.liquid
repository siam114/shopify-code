{%- style -%}


  .video-testimonial-section {
    padding: 50px 0;
    background-color: #ffffff;
    overflow: hidden;
  }


  .testimonial-container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 20px;
  }


  .testimonial-header {
    text-align: center;
    margin-bottom: 60px;
  }


  .subtitle-text {
    font-size: 13px;
    letter-spacing: 0.15em;
    color: #8b7355;
    text-transform: uppercase;
    margin-bottom: 12px;
  }


  .main-title {
    font-family: serif;
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 400;
    color: #1a1a1a;
  }


  .testimonial-slider-outer {
    position: relative;
    overflow: hidden;
    width: 100%;
  }


  .testimonial-flex-track {
    display: flex;
    gap: var(--card-gap);
    transition: transform 0.5s ease;
    will-change: transform;
  }


  .testimonial-item-card {
    flex: 0 0 calc((100% / var(--desktop-cards)) - var(--card-gap));
    min-width: 0;
    user-select: none;
  }


  .media-container {
    position: relative;
    aspect-ratio: 10 / 14;
    border-radius: var(--card-radius);
    overflow: hidden;
    background: #f4f4f4;
    cursor: pointer;
  }


  .media-container img,
  .media-container video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }


  .video-play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 5;
    transition: all 0.3s ease;
  }


  .video-play-btn:hover {
    transform: translate(-50%, -50%) scale(1.08);
  }


  .video-play-btn svg {
    width: 28px;
    height: 28px;
  }


  .card-info-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 30px 20px 20px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, transparent 100%);
    color: #fff;
    z-index: 2;
  }


  .rating-stars {
    color: #ffb800;
    font-size: 14px;
    margin-bottom: 8px;
    display: none;
  }


  .customer-name {
    font-size: 18px;
    margin: 0;
    font-weight: 500;
    color: white;
  }


  .product-detail {
    font-size: 13px;
    opacity: 0.85;
    margin-top: 4px;
    display:  none;
  }


  /* Professional Navigation Styling */
  .testimonial-nav {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 40px;
  }


  .testimonial-arrow {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    border: 1.5px solid #DA9F85;
    background: transparent;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #DA9F85;
    padding: 0;
    outline: none;
  }


  .testimonial-arrow svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }


  .testimonial-arrow:hover {
    background: #DA9F85;
    color: #fff;
  }


  /* ... আপনার আগের সব Popup CSS এখানে থাকবে ... */
  .video-popup {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }


  .video-popup.active {
    opacity: 1;
    visibility: visible;
  }


  .video-popup-content {
    position: relative;
    max-width: 1000px;
    width: 100%;
  }


  .video-popup video {
    width: 100%;
    height: auto;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 16px;
    background: #000;
  }


  .video-popup-close {
    position: absolute;
    top: -50px;
    right: 0;
    width: 42px;
    height: 42px;
    border: none;
    border-radius: 50%;
    background: #fff;
    color: #111;
    font-size: 24px;
    font-weight: 600;
    cursor: pointer;
  }


  @media (max-width: 767px) {
    .testimonial-item-card {
      flex: 0 0 calc((100% / var(--mobile-cards)) - var(--card-gap));
    }
    .video-popup-close {
      top: -45px;
    }
  }
{%- endstyle -%}


<section
  class="video-testimonial-section section-{{ section.id }}"
  data-autoplay="{{ section.settings.autoplay_enabled }}"
  data-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
  data-desktop="{{ section.settings.desktop_cards }}"
  data-mobile="{{ section.settings.mobile_cards }}"
  style="
    --card-gap: {{ section.settings.card_gap }}px;
    --card-radius: {{ section.settings.card_radius }}px;
    --desktop-cards: {{ section.settings.desktop_cards }};
    --mobile-cards: {{ section.settings.mobile_cards }};
  "
>
  <div class="testimonial-container">
    <div class="testimonial-header">
      <p class="subtitle-text">{{ section.settings.subtitle }}</p>
      <h2 class="main-title">{{ section.settings.title }}</h2>
    </div>


    <div class="testimonial-slider-outer">
      <div class="testimonial-flex-track js-slider-track">
        {% for block in section.blocks %}
          <div class="testimonial-item-card js-slide" {{ block.shopify_attributes }}>
            <div
              class="media-container js-open-popup"
              data-video="
                {% if block.settings.video_url != blank %}
                  {{ block.settings.video_url.sources[1].url }}
                {% endif %}
              "
            >
              {% if block.settings.video_url != blank %}
                {{
                  block.settings.video_url
                  | video_tag: autoplay: false, loop: true, muted: true, controls: false, image_size: '800x'
                }}
              {% else %}
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.name }}"
                  loading="lazy"
                >
              {% endif %}


              {% if block.settings.video_url != blank %}
                <button class="video-play-btn" aria-label="Play video">
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M8 5V19L19 12L8 5Z" fill="#111"/>
                  </svg>
                </button>
              {% endif %}


              <div class="card-info-overlay">
                <div class="rating-stars">★★★★★</div>
                <h4 class="customer-name">{{ block.settings.name }}</h4>
                <p class="product-detail">{{ block.settings.product_info }}</p>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>


    {% if section.settings.show_arrows %}
      <div class="testimonial-nav">
        <!-- Professional Arrow Left -->
        <button class="testimonial-arrow js-prev" aria-label="Previous">
          <svg viewBox="0 0 24 24">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
        </button>


        <!-- Professional Arrow Right -->
        <button class="testimonial-arrow js-next" aria-label="Next">
          <svg viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </button>
      </div>
    {% endif %}
  </div>


  <!-- Popup -->
  <div class="video-popup js-video-popup">
    <div class="video-popup-content">
      <button class="video-popup-close js-popup-close">×</button>
      <video
        class="js-popup-video"
        controls
        playsinline
      ></video>
    </div>
  </div>
</section>


<!-- ... আপনার আগের সব JavaScript এখানে থাকবে ... -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('.section-{{ section.id }}');
    if (!section) return;


    const track = section.querySelector('.js-slider-track');
    const slides = [...section.querySelectorAll('.js-slide')];
    const prevBtn = section.querySelector('.js-prev');
    const nextBtn = section.querySelector('.js-next');
    const popup = section.querySelector('.js-video-popup');
    const popupVideo = section.querySelector('.js-popup-video');
    const closePopup = section.querySelector('.js-popup-close');
    const autoplay = section.dataset.autoplay === 'true';
    const speed = parseInt(section.dataset.speed);


    let currentIndex = 0;
    let autoSlide;


    slides.forEach((slide) => {
      const clone = slide.cloneNode(true);
      track.appendChild(clone);
    });


    const allSlides = [...track.querySelectorAll('.js-slide')];


    function updateSlider(withTransition = true) {
      const gap = parseInt(getComputedStyle(section).getPropertyValue('--card-gap'));
      const slideWidth = allSlides[0].offsetWidth + gap;
      track.style.transition = withTransition ? 'transform 0.5s ease' : 'none';
      track.style.transform = `translateX(-${currentIndex * slideWidth}px)`;
    }


    function nextSlide() {
      currentIndex++;
      updateSlider(true);
      if (currentIndex >= slides.length) {
        setTimeout(() => {
          currentIndex = 0;
          updateSlider(false);
        }, 500);
      }
    }


    function prevSlide() {
      if (currentIndex <= 0) {
        currentIndex = slides.length;
        updateSlider(false);
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            currentIndex--;
            updateSlider(true);
          });
        });
      } else {
        currentIndex--;
        updateSlider(true);
      }
    }


    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        stopAutoplay();
        nextSlide();
        startAutoplay();
      });
    }


    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        stopAutoplay();
        prevSlide();
        startAutoplay();
      });
    }


    function startAutoplay() {
      if (!autoplay) return;
      stopAutoplay();
      autoSlide = setInterval(() => {
        nextSlide();
      }, speed);
    }


    function stopAutoplay() {
      clearInterval(autoSlide);
    }


    section.addEventListener('mouseenter', stopAutoplay);
    section.addEventListener('mouseleave', startAutoplay);


    section.querySelectorAll('.js-open-popup').forEach((card) => {
      card.addEventListener('click', () => {
        const videoSrc = card.dataset.video.trim();
        if (!videoSrc) return;
        popup.classList.add('active');
        popupVideo.src = videoSrc;
        popupVideo.play();
        stopAutoplay();
      });
    });


    function closeVideoPopup() {
      popup.classList.remove('active');
      popupVideo.pause();
      popupVideo.src = '';
      startAutoplay();
    }


    closePopup.addEventListener('click', closeVideoPopup);
    popup.addEventListener('click', (e) => {
      if (e.target === popup) closeVideoPopup();
    });


    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeVideoPopup();
    });


    window.addEventListener('resize', () => {
      updateSlider(false);
    });


    updateSlider(false);
    startAutoplay();
  });
</script>


{% schema %}
{
  "name": "Video Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "TÉMOIGNAGES CLIENTS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Elles ont transformé leur routine"
    },
    {
      "type": "checkbox",
      "id": "autoplay_enabled",
      "label": "Enable Auto Slide",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "sec",
      "label": "Slide Duration",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Navigation Arrows",
      "default": true
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Card Gap",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Card Border Radius",
      "default": 18
    },
    {
      "type": "range",
      "id": "desktop_cards",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Cards Per Row Desktop",
      "default": 4
    },
    {
      "type": "range",
      "id": "mobile_cards",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Cards Per Row Mobile",
      "default": 1
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Video Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Poster Image"
        },
        {
          "type": "video",
          "id": "video_url",
          "label": "Upload Video"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Customer Name"
        },
        {
          "type": "text",
          "id": "product_info",
          "label": "Meta Info",
          "default": "Product - 3 months"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Testimonial Slider"
    }
  ]
}
{% endschema %}
