{% schema %}
{
  "name": "Insta Shop Slider PRO V2",
  "settings": [
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1000,
      "max": 1900,
      "step": 20,
      "unit": "px",
      "label": "Section Max Width",
      "default": 1900
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "#livingwithferm"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Heading Font Size",
      "default": 32
    },
    {
      "type": "range",
      "id": "grid_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Cards per Row (Desktop)",
      "default": 4
    },
    {
      "type": "header",
      "content": "Navigation Style"
    },
    {
      "type": "color",
      "id": "nav_bg",
      "label": "Button Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "nav_color",
      "label": "Button Icon/Arrow Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "nav_bg_hover",
      "label": "Button Hover Background",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "nav_color_hover",
      "label": "Button Hover Icon Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "image_block",
      "name": "Gallery Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Gallery Image"
        },
        {
          "type": "text",
          "id": "insta_handle",
          "label": "Instagram Handle",
          "default": "@username"
        },
        {
          "type": "product",
          "id": "product_item",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Insta Shop Slider PRO V2"
    }
  ]
}
{% endschema %}


<style>
  /* Full Section Background */
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.section_bg }};
  }


  .insta-shop-wrapper {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
  }


  .section-heading {
    font-size: {{ section.settings.heading_font_size }}px;
    text-align: center;
    margin-bottom: 30px;
    margin-top: 0px;
    font-family: inherit;
    color: #000; /* Adjusts based on theme or explicit color if needed */
  }


  .insta-container {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 15px;
    scrollbar-width: none;
    scroll-behavior: smooth;
  }
  .insta-container::-webkit-scrollbar { display: none; }


  .insta-item {
    flex: 0 0 calc((100% / {{ section.settings.grid_desktop }}) - (15px * ({{ section.settings.grid_desktop }} - 1) / {{ section.settings.grid_desktop }}));
    scroll-snap-align: start;
    cursor: pointer;
  }


  .insta-item img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .insta-item:hover img { transform: scale(1.02); }


  .insta-handle {
    margin-top: 12px;
    font-size: 14px;
    text-decoration: underline;
    font-weight: 500;
  }


  /* Slider Navigation */
  .insta-nav {
    display: flex;
    justify-content: center;
    gap: 15px;
    margin-top: 30px;
  }


  /* Logic: Hide nav if blocks <= grid_desktop on desktop */
  @media (min-width: 769px) {
    {% if section.blocks.size <= section.settings.grid_desktop %}
      .insta-nav { display: none; }
      .insta-container { overflow: hidden; }
    {% endif %}
  }


  .nav-btn {
    background-color: {{ section.settings.nav_bg }};
    color: {{ section.settings.nav_color }};
    border: none;
    width: 45px;
    height: 45px;
    cursor: pointer;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    font-size: 18px;
  }


  .nav-btn:hover {
    background-color: {{ section.settings.nav_bg_hover }};
    color: {{ section.settings.nav_color_hover }};
  }


  /* Modal Smooth Animation */
  .insta-modal {
    display: none;
    opacity: 0;
    position: fixed;
    z-index: 10000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0,0,0,0.85);
    backdrop-filter: blur(5px);
    transition: opacity 0.4s ease;
    justify-content: center;
    align-items: center;
  }
  .insta-modal.active {
    display: flex;
    opacity: 1;
  }
  .modal-content {
    background: #fff;
    display: flex;
    max-width: 900px;
    width: 95%;
    transform: scale(0.9) translateY(20px);
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    border-radius: 4px;
    overflow: hidden;
    position: relative; /* Added to keep cross button relative to content */
  }
  .insta-modal.active .modal-content {
    transform: scale(1) translateY(0);
  }


  @media (max-width: 768px) {
    .insta-item { flex: 0 0 100%; }
    .modal-content { flex-direction: column; overflow-y: auto; max-height: 90vh; }
    .modal-left, .modal-right { width: 100% !important; }
    .insta-nav { display: flex !important; }
  }


  .modal-left { width: 60%; background: #000; }
  .modal-left img { width: 100%; height: 100%; object-fit: contain; }
  .modal-right { width: 40%; padding: 40px 30px; position: relative; display: flex; flex-direction: column; color: #000; }
 
  /* Fix: Modal Cross Click Issue on Desktop */
  .close-modal {
    position: absolute;
    right: 20px;
    top: 15px;
    font-size: 32px;
    cursor: pointer;
    color: #000;
    line-height: 1;
    z-index: 999; /* Ensure it stays on top */
  }


  .section-heading {
    font-size: 36px;
}
 
  .product-box { display: flex; align-items: center; gap: 15px; margin-top: 25px; border: 1px solid #f0f0f0; padding: 15px; }
  .product-box img { width: 80px; height: 80px; object-fit: cover; }
  .btn-shop { display: block; background: #000; color: #fff; text-align: center; padding: 18px; margin-top: auto; text-decoration: none; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; transition: opacity 0.3s; }
  .btn-shop:hover { opacity: 0.8; }
</style>


<div class="insta-shop-wrapper">
  {% if section.settings.heading != blank %}
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
  {% endif %}


  <div class="insta-container" id="instaSlider-{{ section.id }}">
    {% for block in section.blocks %}
      <div class="insta-item" onclick="openInstaModal('{{ block.id }}')" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          <img src="{{ block.settings.image | img_url: '800x' }}" loading="lazy">
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
        <div class="insta-handle">{{ block.settings.insta_handle }}</div>
      </div>


      <!-- Modal -->
      <div id="modal-{{ block.id }}" class="insta-modal">
        <div class="modal-content">
          <span class="close-modal" onclick="closeInstaModal('{{ block.id }}')">&times;</span>
          <div class="modal-left">
             {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | img_url: '1200x' }}">
            {% endif %}
          </div>
          <div class="modal-right">
            <h3 style="margin-top:0;">{{ block.settings.insta_handle }}</h3>
            <p style="color:#666; font-size: 14px;">Explore this look and shop the featured products below.</p>
           
            {% assign prod = all_products[block.settings.product_item] %}
            {% if prod != blank %}
              <div class="product-box">
                <img src="{{ prod.featured_image | img_url: '200x' }}">
                <div>
                  <div style="font-weight: bold; margin-bottom: 5px;">{{ prod.title }}</div>
                  <div style="color: #000;">{{ prod.price | money }}</div>
                </div>
              </div>
              <a href="{{ prod.url }}" class="btn-shop">Go to product</a>
            {% else %}
              <p style="color: #ff0000; font-size: 12px; margin-top:20px;">Please assign a product to this block.</p>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>


  <div class="insta-nav">
    <button class="nav-btn" onclick="slideInsta('left')" aria-label="Previous">❮</button>
    <button class="nav-btn" onclick="slideInsta('right')" aria-label="Next">❯</button>
  </div>
</div>


<script>
  function slideInsta(direction) {
    const container = document.getElementById('instaSlider-{{ section.id }}');
    const itemWidth = container.querySelector('.insta-item').clientWidth + 15;
    if(direction === 'left') {
      container.scrollBy({ left: -itemWidth, behavior: 'smooth' });
    } else {
      container.scrollBy({ left: itemWidth, behavior: 'smooth' });
    }
  }


  function openInstaModal(id) {
    const modal = document.getElementById('modal-' + id);
    modal.style.display = 'flex';
    setTimeout(() => { modal.classList.add('active'); }, 10);
    document.body.style.overflow = 'hidden';
  }


  function closeInstaModal(id) {
    const modal = document.getElementById('modal-' + id);
    modal.classList.remove('active');
    setTimeout(() => { modal.style.display = 'none'; }, 400);
    document.body.style.overflow = 'auto';
  }


  window.onclick = function(event) {
    if (event.target.classList.contains('insta-modal')) {
      const modalId = event.target.id.replace('modal-', '');
      closeInstaModal(modalId);
    }
  };
</script>
